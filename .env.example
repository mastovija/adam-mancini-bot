# ─────────────────────────────────────────────────────────────────────
# Adam Mancini Bot - Variables de entorno
# ─────────────────────────────────────────────────────────────────────
# INSTRUCCIONES:
# 1. Copia este archivo:  cp .env.example .env
# 2. Rellena los valores
# 3. NUNCA subas .env a GitHub (ya está en .gitignore)
# ─────────────────────────────────────────────────────────────────────

# ── Twitter/X ──────────────────────────────────────────────────────
# Cualquier cuenta tuya de Twitter vale, no necesita ser verificada
TWITTER_USERNAME=tu_usuario_sin_arroba
TWITTER_EMAIL=tu_email@gmail.com
TWITTER_PASSWORD=tu_contraseña

# ── Anthropic API (Claude Haiku para parseo barato) ────────────────
# Consigue tu key en: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Alpaca Markets (datos SPY en tiempo real, gratis) ──────────────
# 1. Crea cuenta gratis en: https://alpaca.markets/
# 2. Ve a Paper Trading → API Keys → Generate New Key
ALPACA_API_KEY=PKXXXXXXXXXXXXXXXX
ALPACA_SECRET_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Telegram ────────────────────────────────────────────────────────
# 1. Abre Telegram y busca @BotFather
# 2. Escribe /newbot y sigue los pasos → te da el TOKEN
# 3. Para el CHAT_ID: habla con @userinfobot en Telegram
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=123456789

# ── Substack (se usa en Fase 3, déjalo vacío por ahora) ────────────
# Cuando te suscribas al newsletter de pago, pon aquí las cookies
# Cómo obtenerlas: Chrome → F12 → Application → Cookies → substack.com
SUBSTACK_COOKIES=
