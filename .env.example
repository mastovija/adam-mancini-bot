# ─────────────────────────────────────────────────────────────────────
# Adam Mancini Bot - Environment variables
# ─────────────────────────────────────────────────────────────────────
# INSTRUCTIONS:
# 1. Copy this file:  cp .env.example .env
# 2. Fill in the values
# 3. NEVER push .env to GitHub (it's already in .gitignore)
# ─────────────────────────────────────────────────────────────────────

# ── Twitter/X ──────────────────────────────────────────────────────
# Any Twitter account of yours works, it doesn't need to be verified
TWITTER_USERNAME=your_username_without_at
TWITTER_EMAIL=your_email@gmail.com
TWITTER_PASSWORD=your_password

# ── Anthropic API (Claude Haiku for cheap parsing) ─────────────────
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Alpaca Markets (real-time SPY data, free) ──────────────────────
# 1. Create a free account at: https://alpaca.markets/
# 2. Go to Paper Trading → API Keys → Generate New Key
ALPACA_API_KEY=PKXXXXXXXXXXXXXXXX
ALPACA_SECRET_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Telegram ────────────────────────────────────────────────────────
# 1. Open Telegram and search for @BotFather
# 2. Type /newbot and follow the steps → it gives you the TOKEN
# 3. For the CHAT_ID: talk to @userinfobot on Telegram
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=123456789

# ── Substack (used in Phase 3, leave it empty for now) ─────────────
# When you subscribe to the paid newsletter, put the cookies here
# How to get them: Chrome → F12 → Application → Cookies → substack.com
SUBSTACK_COOKIES=
